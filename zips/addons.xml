<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addons>
    <addon id="plugin.program.flixwizard" name="Flixwizard" version="1.0.0" provider-name="FlixStudios">
        <requires>
            <import addon="xbmc.python" version="3.0.0" />
        </requires>
        <extension point="xbmc.python.pluginsource" library="addon.py">
            <provides>executable</provides>
        </extension>
        <extension point="xbmc.service" library="service.py" />
        <extension point="xbmc.addon.metadata">
            <summary lang="en_GB">Flixwizard is a lightweight template for installing builds on Kodi. Has some code from Aftermath Wizard by Surfacingx. Skin Switch by OpenELEQ. Base code by BYB. Credits to them and all others who contributed. Please report any bugs to @slamious on Telegram/Twitter.</summary>
            <description lang="en_GB">Kodi Wizard</description>
            <disclaimer lang="en_GB">This Addon contains no content</disclaimer>
            <language>en</language>
            <platform>all</platform>
            <license>GPL-2.0-or-later</license>
            <forum />
            <website />
            <email />
            <source />
            <news />
            <assets>
                <icon>resources/icon.png</icon>
                <fanart>resources/fanart.jpg</fanart>
                <banner />
                <clearlogo />
                <screenshot />
            </assets>
        </extension>
    </addon>
    <addon id="repository.flixstudioss" name="[B][COLOR lightblue]Flix[/B][COLOR white]Studioss Repository[/COLOR]" version="1.0.0" provider-name="FlixStudioss">
        <requires>
            <import addon="xbmc.python" version="3.0.0" />
        </requires>
        <extension point="xbmc.addon.repository" name="FlixStudioss Repository">
            <dir>
                <info compressed="false">https://raw.githubusercontent.com/flixstu/flixstu.github.io/main/zips/addons.xml</info>
                <checksum>https://raw.githubusercontent.com/flixstu/flixstu.github.io/main/zips/addons.xml.md5</checksum>
                <datadir zip="true">https://raw.githubusercontent.com/flixstu/flixstu.github.io/main/zips/</datadir>
            </dir>
        </extension>
        <extension point="xbmc.addon.metadata">
            <summary lang="en">Official FlixStudioss Kodi Repository</summary>
            <description lang="en">Official FlixStudioss Repository for all our Kodi Addons.</description>
            <platform>all</platform>
            <assets>
                <icon>icon.png</icon>
            </assets>
        </extension>
    </addon>
</addons>
